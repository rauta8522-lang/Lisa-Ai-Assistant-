# ====================================================
# LISA - AI Voice Assistant Configuration
# ====================================================

# Required: Google Gemini AI API Key
# Get it from: https://aistudio.google.com/app/apikey
# इसे https://aistudio.google.com/app/apikey से प्राप्त करें
VITE_GEMINI_API_KEY="your_gemini_api_key_here"

# Optional: YouTube API Key for video playback
# Get it from: https://console.cloud.google.com/
VITE_YOUTUBE_API_KEY="your_youtube_api_key_here"

# App Configuration
# ===========================

# Application URL (for social sharing, redirects)
APP_URL="http://localhost:3000"

# API Server URL (if using custom backend)
VITE_API_URL="http://localhost:3000/api"

# Environment Mode
VITE_ENV="development"

# Logging Level: debug, info, warn, error
VITE_LOG_LEVEL="info"

# ====================================================
# Deployment-Specific Configurations
# ====================================================

# For Local Development:
# npm run dev

# For Production Build:
# npm run build
# npm run preview

# For Docker:
# docker build -t lisa-app .
# docker run -p 3000:3000 -e VITE_GEMINI_API_KEY=your_key lisa-app

# For Cloud Deployment (Vercel, Netlify, etc.):
# Set these variables in your cloud provider's environment variables panel

# ====================================================
# Notes / नोट्स
# ====================================================

# 1. NEVER commit this file with real keys
#    इस फ़ाइल को real keys के साथ कभी commit न करें

# 2. For production, use secure environment variable management
#    Production के लिए secure environment variable management use करें

# 3. Different keys for different environments (dev, staging, prod)
#    अलग-अलग environments के लिए अलग keys रखें

# 4. Rotate API keys regularly for security
#    Security के लिए नियमित रूप से API keys rotate करें

# 5. Monitor API usage and set quotas
#    API usage monitor करें और quotas set करें
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
